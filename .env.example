CALENDARIO_URL=http://127.0.0.1/calendario
TZ=America/Mexico_City
DAYS_AHEAD=1
CRON_HOUR=21
CRON_MINUTE=0
API_TOKEN=your_token_here
# INTERVAL_MINUTES=3  # solo para pruebas

# Picks job
PICKS_URL=http://web:8000/picks/match
DATABASE_URL=postgresql://user:password@host:5432/dbname
PICKS_CONNECT_TIMEOUT=5
PICKS_READ_TIMEOUT=60
PICKS_MAX_RETRIES=1
PICKS_RETRY_BACKOFF=1.0
PICKS_INTERVAL_MINUTES=10
